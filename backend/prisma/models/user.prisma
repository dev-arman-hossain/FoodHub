model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  password        String
  role            Role             @default(CUSTOMER)
  status          UserStatus       @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  avatar          String?
  orders          Order[]
  providerProfile ProviderProfile?
  reviews         Review[]

  @@map("users")
}
